{
  "schema": 2,

  "permissions": [
    "tools.invoke",
    "storage.read",
    "storage.write"
  ],

  "required_executas": [
    {
      "tool_id": "tool-dev-notes-summarizer"
    }
  ],

  "tags": [
    "mini-notes"
  ],

  "ui": {
    "bundle": {
      "format": "static-spa",
      "entry": "index.html",
      "external_origins": []
    },

    "views": [
      {
        "name": "main",
        "title": "Mini Notes",
        "default": true,

        "default_size": {
          "w": 480,
          "h": 360
        },

        "min_size": {
          "w": 320,
          "h": 240
        }
      }
    ],

    "host_api": {
      "tools": [
        "tool-dev-notes-summarizer"
      ],

      "storage": [
        "get",
        "set"
      ],

      "window": [
        "set_title",
        "ready"
      ]
    },

    "csp_overrides": {},

    "state_merge": "last_writer_wins"
  },

  "dev": {
    "fixtures": [],
    "seed_storage": {},
    "user_id": 1
  }
}